# ============================================================
#  .env.example  —  Copy to .env.local for development
#  Copy values to Vercel Dashboard for production
# ============================================================

# WordPress Backend
NEXT_PUBLIC_WP_BASE_URL=
NEXT_PUBLIC_WP_API_URL=
NEXT_PUBLIC_WP_REST_URL=
NEXT_PUBLIC_WP_MEDIA_URL=
NEXT_PUBLIC_WP_JWT_URL=

# WordPress credentials (server-side only, never NEXT_PUBLIC_)
WP_API_USERNAME=
WP_API_PASSWORD=

# Frontend
NEXT_PUBLIC_SITE_URL=

# ISR revalidation secret (server-side only)
REVALIDATE_SECRET=
